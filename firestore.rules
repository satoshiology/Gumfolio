rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Helpers
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0;
    }

    function isValidSale(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
               data.product_id is string && isValidId(data.product_id) &&
               data.price is number && data.price >= 0;
    }

    function isValidMessage(data) {
      return data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() > 0 &&
             data.createdAt is string; // Simplified for this draft
    }

    // MATCH BLOCKS
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      
      match /products/{productId} {
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidProduct(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidProduct(incoming());
      }
      
      match /sales/{saleId} {
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidSale(incoming());
      }
      
      match /chatHistory/{messageId} {
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidMessage(incoming());
      }
    }
  }
}
